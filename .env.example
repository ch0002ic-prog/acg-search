PROJECT_NAME=ACG Search SG
DB_PATH=./data/articles.db
VECTOR_DIR=./data/vector-store
VECTOR_BACKEND=local
REQUEST_SLOW_LOG_MS=750
SOURCE_HEALTH_STALE_HOURS=24
SOURCE_HEALTH_RUNS_RETENTION_DAYS=30
DEFAULT_FEED_LIMIT=12
LOCAL_VECTOR_PREFILTER_LIMIT=400
SOURCE_LIMIT_PER_FEED=12
ENABLE_FULL_TEXT_FETCH=false
DISABLE_HTTP_CACHE=true
ALLOW_REMOTE_REFRESH=false

# LLM configuration
LLM_PROVIDER=none
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=
ENABLE_LLM_ENRICHMENT=false

# Valid providers: none, ollama, openai, openai_compatible
