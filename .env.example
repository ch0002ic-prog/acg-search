PROJECT_NAME=ACG Search SG
DB_PATH=./data/articles.db
DATABASE_URL=
STATE_SNAPSHOT_KEY=acg-search-runtime
STATE_STORE_CONNECT_TIMEOUT_SECONDS=10
VECTOR_DIR=./data/vector-store
VECTOR_BACKEND=local
REQUEST_SLOW_LOG_MS=750
LLM_TIMEOUT_SECONDS=60
LLM_EXPAND_TIMEOUT_SECONDS=2.5
LLM_RERANK_TIMEOUT_SECONDS=4.5
LLM_DIGEST_TIMEOUT_SECONDS=3.5
LLM_MAX_TOKENS=256
LLM_EXPAND_MAX_TOKENS=64
LLM_RERANK_MAX_TOKENS=96
LLM_DIGEST_MAX_TOKENS=96
LLM_CACHE_TTL_SECONDS=900
LLM_CACHE_MAX_ENTRIES=256
EMBEDDING_TIMEOUT_SECONDS=45
SOURCE_HEALTH_STALE_HOURS=24
SOURCE_HEALTH_RUNS_RETENTION_DAYS=30
DEFAULT_FEED_LIMIT=12
LOCAL_VECTOR_PREFILTER_LIMIT=400
SOURCE_LIMIT_PER_FEED=12
ENABLE_FULL_TEXT_FETCH=false
DISABLE_HTTP_CACHE=true
ALLOW_REMOTE_REFRESH=false

# LLM configuration
LLM_PROVIDER=none
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=
ENABLE_LLM_ENRICHMENT=false
WARM_LOCAL_MODELS_ON_STARTUP=true

# Semantic embedding configuration
EMBEDDING_PROVIDER=none
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_BATCH_SIZE=12

# Valid providers: none, ollama, openai, openai_compatible
